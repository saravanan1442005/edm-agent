<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.EDMAgent" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="colorPrimary">@color/windows_blue</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/windows_blue_light</item>
        <item name="colorOnPrimaryContainer">@color/windows_blue_dark</item>
        
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_variant_light</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        
        <item name="android:statusBarColor">@color/windows_blue</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>

    <style name="Theme.EDMAgent" parent="Base.Theme.EDMAgent" />

    <style name="Widget.EDMAgent.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <style name="Widget.EDMAgent.GlassCard" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/glass_surface</item>
        <item name="strokeColor">@color/glass_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>
    
    <style name="Widget.EDMAgent.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">8dp</item>
    </style>

    <style name="Widget.EDMAgent.PrimaryButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">14dp</item>
        <item name="backgroundTint">@color/primary_button</item>
        <item name="android:textColor">@color/primary_button_text</item>
        <item name="iconTint">@color/primary_button_text</item>
    </style>

    <style name="Widget.EDMAgent.OutlineButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">14dp</item>
        <item name="strokeColor">@color/glass_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>
</resources>